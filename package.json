{
  "name": "fridgechef",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.34.4",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "@tailwindcss/oxide",
      "esbuild",
      "prisma"
    ]
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter @fridgechef/api --filter @fridgechef/web dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "db:up": "docker compose up -d db",
    "db:migrate": "pnpm --filter @fridgechef/api db:migrate",
    "db:seed": "pnpm --filter @fridgechef/api db:seed",
    "db:studio": "pnpm --filter @fridgechef/api db:studio",
    "start": "pnpm --filter @fridgechef/api start"
  }
}
